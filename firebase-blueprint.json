{
  "entities": {
    "AudioFile": {
      "title": "AudioFile",
      "description": "Represents an audio file uploaded or generated by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["local", "remote", "tts"] },
        "duration": { "type": "number" },
        "createdAt": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["id", "name", "url", "type", "createdAt", "uid"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Represents a broadcast schedule.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "time": { "type": "string" },
        "audioId": { "type": "string" },
        "label": { "type": "string" },
        "days": { "type": "array", "items": { "type": "number" } },
        "enabled": { "type": "boolean" },
        "section": { "type": "string", "enum": ["morning", "afternoon"] },
        "uid": { "type": "string" }
      },
      "required": ["id", "time", "audioId", "label", "days", "enabled", "section", "uid"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Represents an AI generated announcement.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "voice": { "type": "string" },
        "speed": { "type": "number" },
        "pitch": { "type": "number" },
        "createdAt": { "type": "number" },
        "uid": { "type": "string" }
      },
      "required": ["id", "text", "voice", "speed", "pitch", "createdAt", "uid"]
    }
  },
  "firestore": {
    "/users/{userId}/audioFiles/{audioFileId}": {
      "schema": { "$ref": "#/entities/AudioFile" },
      "description": "Audio files owned by the user."
    },
    "/users/{userId}/schedules/{scheduleId}": {
      "schema": { "$ref": "#/entities/Schedule" },
      "description": "Schedules owned by the user."
    },
    "/users/{userId}/announcements/{announcementId}": {
      "schema": { "$ref": "#/entities/Announcement" },
      "description": "Announcements owned by the user."
    }
  }
}
